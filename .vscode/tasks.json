{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar Release portable",
      "type": "shell",
      "command": "${workspaceFolder}/build.sh",
      "args": [
        "release"
      ],
      "windows": {
        "command": "${workspaceFolder}\\build_windows_portable.cmd",
        "args": [
          "Release",
          "x64"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Compilar Debug portable",
      "type": "shell",
      "command": "${workspaceFolder}/build.sh",
      "args": [
        "debug"
      ],
      "windows": {
        "command": "${workspaceFolder}\\build_windows_portable.cmd",
        "args": [
          "Debug",
          "x64"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "Compilar y ejecutar tests",
      "type": "shell",
      "command": "${workspaceFolder}/run_tests.sh",
      "windows": {
        "command": "${workspaceFolder}\\build_windows_portable.cmd",
        "args": [
          "Debug",
          "x64",
          "--tests"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ],
      "group": "test"
    }
  ]
}
